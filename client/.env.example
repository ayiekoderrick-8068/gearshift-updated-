# Copy this file to .env and set the URL of your running Flask API.
# Locally this is your Flask dev server. After deploying the backend to
# Render, change this to the live Render URL in your Vercel project's env
# var settings (not in this file - .env isn't committed).
#
# Using 127.0.0.1 instead of "localhost" on purpose: macOS Screen Time's
# content filter (Content & Privacy Restrictions -> Web Content) blocks the
# hostname "localhost" for some users but doesn't touch raw IPs, causing a
# confusing 403 "Access to localhost was denied" page. If you use this URL
# AND open the frontend itself at http://127.0.0.1:5173 (not localhost:5173),
# you avoid the whole problem. See SETUP_GUIDE.md's troubleshooting table.
VITE_API_URL=http://127.0.0.1:5000
