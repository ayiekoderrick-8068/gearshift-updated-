[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

# Core runtime deps needed to run the app locally with SQLite. Deliberately
# does NOT include the Postgres driver or a production WSGI server - those
# are only needed once this is deployed on Render, and pinning them here
# would force everyone doing `pipenv install` locally to compile psycopg2
# from source (it needs a local Postgres install just to build). See the
# "Deploying" section in README.md for the one extra command Render needs.
[packages]
flask = "==3.0.3"
flask-sqlalchemy = "==3.1.1"
flask-bcrypt = "==1.0.1"
flask-cors = "==4.0.1"
pyjwt = "==2.9.0"
python-dotenv = "==1.0.1"

[dev-packages]

# No [requires] python_version pin here on purpose - your three machines
# almost certainly have three different Python versions installed, and
# pinning one would print a mismatch warning for everyone except whoever
# picked the pin. Pipenv works fine without it; it just uses whatever
# `python3` resolves to on each machine.
