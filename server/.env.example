# Copy this file to .env and fill in real values. .env is gitignored -
# never commit real secrets.

# Leave blank locally to use SQLite (server/gearshift.db is created automatically).
# In production (Render) this is the Postgres connection string Render gives you.
DATABASE_URL=

SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-different-long-random-string

# Frontend origin(s) allowed to call this API, comma-separated.
# Using 127.0.0.1 instead of "localhost" on purpose - see the comment in
# client/.env.example for why (macOS Screen Time content filtering).
CORS_ORIGINS=http://127.0.0.1:5173
